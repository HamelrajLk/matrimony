  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  url        String
  caption    String?
  isFeatured Boolean @default(false) @map("is_featured")
  sortOrder  Int     @default(0)     @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([partnerId, isFeatured])
  @@map("photography_photos")
}

model PhotographyEvent {
  id        Int     @id @default(autoincrement())
  partnerId Int     @map("partner_id")
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  eventDate   DateTime @map("event_date")

  photos PhotographyEventPhoto[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([partnerId, eventDate])
  @@map("photography_events")
}

model PhotographyEventPhoto {
  id      Int              @id @default(autoincrement())
  eventId Int              @map("event_id")
  event   PhotographyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  url     String
  caption String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("photography_event_photos")
}

