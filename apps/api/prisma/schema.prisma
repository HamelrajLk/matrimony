// ────────────────────────────────────────────────────────────────
//  SUBSCRIPTION SYSTEM
// ────────────────────────────────────────────────────────────────

// Plans: FREE, GOLD, DIAMOND, PLATINUM
model SubscriptionPlan {
  id          Int     @id @default(autoincrement())
  value       String  @unique  // FREE | GOLD | DIAMOND | PLATINUM
  label       String
  description String?
  badge       String?          // e.g. "TOP SELLER", "BEST VALUE"
  color       String  @default("#F4A435")  // accent colour for UI
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  prices        SubscriptionPlanPrice[]
  features      PlanFeatureAssignment[]
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// Pricing per plan per duration
model SubscriptionPlanPrice {
  id              Int    @id @default(autoincrement())
  planId          Int    @map("plan_id")
  plan            SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  durationMonths  Int    @map("duration_months")   // 3 | 6 | 12
  priceAmount     Float  @map("price_amount")       // in LKR
  originalPrice   Float? @map("original_price")     // before discount
  discountPercent Int?   @map("discount_percent")

  @@unique([planId, durationMonths])
  @@map("subscription_plan_prices")
}

// Feature definitions (admin-managed)
model SubscriptionFeature {
  id          Int     @id @default(autoincrement())
  key         String  @unique  // e.g. send_unlimited_messages
  title       String
  description String?
  icon        String?          // emoji or icon name
  // Who this feature applies to — comma-separated or single:
  // INDIVIDUAL | MATCHMAKER | PHOTOGRAPHER | VENUE | CATERING | etc. | ALL
  audience    String
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  planAssignments PlanFeatureAssignment[]

  @@map("subscription_features")
}

// Which features belong to which plan (with included/excluded state)
model PlanFeatureAssignment {
  id        Int     @id @default(autoincrement())
  planId    Int     @map("plan_id")
  plan      SubscriptionPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId Int     @map("feature_id")
  feature   SubscriptionFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  included  Boolean @default(true)   // false = shown as crossed-out/unavailable
  quantity  String?                  // e.g. "40", "Unlimited", "3 Months"
  note      String?                  // e.g. "per month", "(Unlimited for Accepted Matches)"
  sortOrder Int     @default(0) @map("sort_order")

  @@unique([planId, featureId])
  @@map("plan_feature_assignments")
}

// Actual user subscription records
model UserSubscription {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId         Int      @map("plan_id")
  plan           SubscriptionPlan @relation(fields: [planId], references: [id])
  durationMonths Int      @map("duration_months")
  priceAmount    Float    @map("price_amount")
  currency       String   @default("LKR")
  status         String   @default("ACTIVE")  // ACTIVE | EXPIRED | CANCELLED
  startedAt      DateTime @default(now()) @map("started_at")
  expiresAt      DateTime @map("expires_at")
  paymentRef     String?  @map("payment_ref")
  receiptImageUrl String? @map("receipt_image_url")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, status])
  @@map("user_subscriptions")
}

// ────────────────────────────────────────────────────────────────
//  MAKEUP ARTIST & BEAUTY — SERVICE-SPECIFIC MODELS
// ────────────────────────────────────────────────────────────────

model MakeupArtistProfile {
  id        String  @id @default(uuid())
  partnerId Int     @unique @map("partner_id")
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // ── Professional ──
  artistType       String   @default("freelance") @map("artist_type")
  // "freelance" | "salon" | "team"
  teamSize         Int?     @default(1) @map("team_size")
  yearsExperience  Int?     @map("years_experience")
  specialistBio    String?  @map("specialist_bio") @db.Text
  brandsUsed       String[] @map("brands_used")
  languages        String[] // ["Sinhala","Tamil","English"]

  // ── Travel & Service Area ──
  // JSON: [{ country: "Sri Lanka", cities: ["Colombo","Kandy"] }, ...]
  serviceAreas      Json?    @map("service_areas")
  homeService       Boolean  @default(false) @map("home_service")
  travelIslandWide  Boolean  @default(false) @map("travel_island_wide")
  outstationTravel  Boolean  @default(false) @map("outstation_travel")
  travelFee         String?  @map("travel_fee")

  // ── Booking Rules ──
  advanceNoticeDays  Int?     @default(7)  @map("advance_notice_days")
  depositRequired    Boolean  @default(false) @map("deposit_required")
  depositPercent     Int?     @map("deposit_percent")
  earlySurcharge     Boolean  @default(false) @map("early_surcharge")
  earlySurchargeAmt  Decimal? @map("early_surcharge_amt") @db.Decimal(10, 2)
  cancellationPolicy String?  @map("cancellation_policy") @db.Text

  // ── Social ──
  whatsapp  String?
  instagram String?
  facebook  String?
  website   String?

  // ── Analytics ──
  totalViews  Int @default(0) @map("total_views")
  totalShares Int @default(0) @map("total_shares")

  // ── Search denorm fields (for future AI chatbot queries) ──
  searchCountry  String?  @map("search_country")
  searchCity     String?  @map("search_city")
  searchPriceMin Decimal? @map("search_price_min") @db.Decimal(10, 2)
  searchPriceMax Decimal? @map("search_price_max") @db.Decimal(10, 2)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  packages           MakeupPackage[]
  portfolioAlbums    PortfolioAlbum[]
  certifications     MakeupCertification[]
  events             MakeupEvent[]
  enquiries          MakeupEnquiry[]
  profileViews       MakeupProfileView[]
  availabilityBlocks AvailabilityBlock[]

  @@index([searchCountry])
  @@index([searchCity])
  @@map("makeup_artist_profiles")
}

model MakeupCertification {
  id                    String              @id @default(uuid())
  makeupArtistProfileId String              @map("makeup_artist_profile_id")
  profile               MakeupArtistProfile @relation(fields: [makeupArtistProfileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  fileUrl     String  @map("file_url")
  fileType    String  @map("file_type") // "pdf" | "image"
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([makeupArtistProfileId])
  @@map("makeup_certifications")
}

model MakeupPackage {
  id                    String              @id @default(uuid())
  makeupArtistProfileId String              @map("makeup_artist_profile_id")
  profile               MakeupArtistProfile @relation(fields: [makeupArtistProfileId], references: [id], onDelete: Cascade)

  name           String
  tagline        String?
  description    String?  @db.Text
  price          Decimal  @db.Decimal(10, 2)
  currency       String   @default("LKR")
  isNegotiable   Boolean  @default(false) @map("is_negotiable")
  maxPersons     Int?     @default(1) @map("max_persons")
  durationHours  Decimal? @map("duration_hours") @db.Decimal(4, 1)
  validityNote   String?  @map("validity_note")
  coverImageUrl  String?  @map("cover_image_url")
  inclusions     String[]
  exclusions     String[]
  isFeatured     Boolean  @default(false) @map("is_featured")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

